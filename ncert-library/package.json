{
  "name": "ncert-library",
  "version": "0.1.0",
  "private": true,
  "description": "World-class open-source NCERT digital library platform",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:website": "turbo build --filter=@ncert-library/website",
    "build:docs": "turbo build --filter=@ncert-library/docs",
    "lint": "turbo lint",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "clean": "turbo clean",
    "scrape": "turbo run scrape --filter=@ncert-library/scraper",
    "generate:metadata": "turbo run generate --filter=@ncert-library/metadata",
    "generate:search": "turbo run generate --filter=@ncert-library/search-index",
    "merge:pdfs": "turbo run merge --filter=@ncert-library/pdf-merger",
    "sync:firebase": "turbo run sync --filter=@ncert-library/metadata",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && changeset publish",
    "ci:full": "node tools/scripts/dist/ci-full.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.28.1",
    "@changesets/changelog-github": "^0.5.1",
    "@types/node": "^22.15.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,mjs,cjs}": [
      "biome check --write",
      "biome format --write"
    ],
    "*.{json,md,yaml,yml}": ["biome format --write"]
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp",
      "@firebase/util",
      "protobufjs"
    ]
  }
}

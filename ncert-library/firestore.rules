rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Books collection: public read, admin-only write
    match /books/{bookCode} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Class index: public read
    match /classes/{classId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Subject index: public read
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Language index: public read
    match /languages/{langId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

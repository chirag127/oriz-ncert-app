---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <Header slot="header" />
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-display font-bold text-ncert-900 dark:text-ncert-100 mb-6">
      About NCERT Library
    </h1>
    <div class="prose prose-lg max-w-none prose-headings:font-serif prose-headings:text-ncert-900 prose-a:text-ncert-600 prose-a:no-underline hover:prose-a:underline prose-code:font-mono prose-code:text-ncert-800 prose-pre:bg-gray-900 prose-pre:text-gray-100">
      <p>
        NCERT Library is a free, open-source digital library that makes NCERT textbooks
        accessible to everyone. Our mission is to provide a modern, fast, and beautiful
        way to browse, search, and download NCERT textbooks.
      </p>
      <h2>Features</h2>
      <ul>
        <li>Complete collection of NCERT textbooks (Class I-XII)</li>
        <li>Fast full-text search across all books</li>
        <li>Dark mode and customizable reading experience</li>
        <li>Offline support through PWA</li>
        <li>Keyboard shortcuts for power users</li>
        <li>Bookmarks and reading progress tracking</li>
        <li>Export in multiple formats (JSON, CSV, OPDS)</li>
      </ul>
      <h2>Technical</h2>
      <p>
        Built with Astro, React, TypeScript, Tailwind CSS, and Turborepo.
        All metadata is stored in Firebase Firestore with daily GitHub Actions
        keeping everything up to date.
      </p>
      <h2>Open Source</h2>
      <p>
        This project is open source under the MIT license.
        <a href="https://github.com/chirag127/ncert-library">Contribute on GitHub</a>.
      </p>
    </div>
  </div>
  <Footer slot="footer" />
</BaseLayout>

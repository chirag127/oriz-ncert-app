---
import fs from 'node:fs';
import path from 'node:path';
import type { BookMetadata } from '@ncert-library/types';
import BookDetail from '../../components/BookDetail.tsx';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const booksPath = path.resolve(
    process.cwd(),
    '..',
    '..',
    'data',
    'metadata',
    'books.json',
  );
  let books: BookMetadata[] = [];
  try {
    if (fs.existsSync(booksPath)) {
      const raw = fs.readFileSync(booksPath, 'utf-8');
      books = JSON.parse(raw);
    }
  } catch {
    // data not available yet
  }
  if (books.length === 0) return [];
  return books.map((book) => ({
    params: { bookCode: book.bookCode },
    props: { book },
  }));
}

type Props = {
  book: BookMetadata | undefined;
};

const { book } = Astro.props as Props;
const bookCode = Astro.params.bookCode;
---

<BaseLayout
  title={book?.title ?? 'Book Not Found'}
  description={book?.description ?? `NCERT textbook ${bookCode}`}
>
  <Header slot="header" />
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <BookDetail bookCode={bookCode!} client:load />
  </div>
  <Footer slot="footer" />
</BaseLayout>

---
const features = [
  {
    title: 'Complete Collection',
    description: 'All NCERT textbooks from Class I to XII in one place.',
    icon: '📚',
  },
  {
    title: 'Fast Search',
    description: 'Full-text search across all books with instant results.',
    icon: '🔍',
  },
  {
    title: 'Dark Mode',
    description: 'Easy on the eyes with a beautiful dark theme.',
    icon: '🌙',
  },
  {
    title: 'Offline Access',
    description: 'Install as a PWA and access books offline.',
    icon: '📱',
  },
  {
    title: 'PDF Downloads',
    description: 'Download complete books or individual chapters.',
    icon: '📥',
  },
  {
    title: 'Open Source',
    description: 'Fully open source under the MIT license.',
    icon: '🔓',
  },
];
---

<section class="py-20 bg-white/30 dark:bg-gray-900/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-display font-bold text-ncert-900 dark:text-ncert-100">
        Why NCERT Library?
      </h2>
      <p class="mt-3 text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        A modern, fast, and beautiful way to access NCERT textbooks.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="p-6 rounded-xl border border-paper-200/50 bg-white/80 dark:bg-gray-900/80 dark:border-gray-800 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300">
          <span class="text-2xl mb-3 block">{feature.icon}</span>
          <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">{feature.title}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

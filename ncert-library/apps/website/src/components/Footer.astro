---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-paper-200 dark:border-gray-800 bg-white/50 dark:bg-gray-950/50 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="col-span-1 md:col-span-2">
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-ncert-600 flex items-center justify-center text-white font-bold text-sm">
            N
          </div>
          <span class="font-display text-lg font-bold text-ncert-900 dark:text-ncert-100">
            NCERT Library
          </span>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 max-w-md">
          A free, open-source digital library for NCERT textbooks.
          Browse, search, and download textbooks for all classes.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-sm text-gray-900 dark:text-gray-100 mb-3">Browse</h3>
        <ul class="space-y-2">
          <li><a href="/books" class="text-sm text-gray-600 dark:text-gray-400 hover:text-ncert-600 transition-colors">All Books</a></li>
          <li><a href="/search" class="text-sm text-gray-600 dark:text-gray-400 hover:text-ncert-600 transition-colors">Search</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-sm text-gray-900 dark:text-gray-100 mb-3">About</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-gray-600 dark:text-gray-400 hover:text-ncert-600 transition-colors">About Us</a></li>
          <li><a href="https://github.com/chirag127/ncert-library" class="text-sm text-gray-600 dark:text-gray-400 hover:text-ncert-600 transition-colors">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-paper-200 dark:border-gray-800">
      <p class="text-xs text-gray-500 dark:text-gray-500 text-center">
        &copy; {currentYear} NCERT Library. Not affiliated with NCERT.
        Textbooks are the property of NCERT.
      </p>
    </div>
  </div>
</footer>

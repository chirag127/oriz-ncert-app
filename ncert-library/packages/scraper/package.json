{
  "name": "@ncert-library/scraper",
  "version": "0.1.0",
  "private": true,
  "description": "NCERT textbook scraper using Playwright and Cheerio",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "scrape": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ncert-library/types": "workspace:*",
    "@ncert-library/shared": "workspace:*",
    "cheerio": "^1.0.0",
    "playwright": "^1.53.0",
    "node-fetch": "^3.3.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}

{
  "name": "@ncert-library/search-index",
  "version": "0.1.0",
  "private": true,
  "description": "Prebuilt search indexes for NCERT Library using FlexSearch",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ncert-library/types": "workspace:*",
    "flexsearch": "^0.7.43"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
